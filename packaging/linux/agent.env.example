# Install as /etc/em-station/agent.env with owner root:em-station and mode 0640.
EM_BACKEND_URL=https://em-backend.example.internal/api/
EM_BACKEND_TIMEOUT_SECONDS=15
EM_BACKEND_ALLOW_HTTP=false
EM_DEVICE_INVENTORY=/etc/em-station/devices.json

# Optional comma-separated desktop user UIDs allowed to connect to the agent socket.
# Keep empty to rely on the socket group permissions managed by systemd/package scripts.
EM_AGENT_ALLOWED_UIDS=
